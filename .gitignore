# ============================================================
# miniCV .gitignore
# CMake is the source of truth. IDE project/cache/build outputs stay local.
# ============================================================

# -------------------------
# OS generated files
# -------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100/
.Trashes/
.fseventsd/

Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -------------------------
# CMake build outputs
# -------------------------
build/
build-*/
out/
out-*/
_build/
cmake-build-*/

CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
Testing/

# Generated by some CMake/Ninja workflows. Keep local unless explicitly curated.
compile_commands.json

# User-local CMake presets. Shared presets belong in CMakePresets.json.
CMakeUserPresets.json

# -------------------------
# Build system outputs
# -------------------------
.ninja_deps
.ninja_log
*.ninja
*.make
Makefile

# -------------------------
# Compiler and linker outputs
# -------------------------
*.o
*.obj
*.lo
*.la
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.pdb
*.idb
*.ilk
*.exp
*.map
*.dSYM/

# -------------------------
# Coverage and profiling
# -------------------------
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata
coverage/
htmlcov/

# -------------------------
# Visual Studio / MSVC
# -------------------------
.vs/
ipch/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb
*.opendb
Browse.VC.db

# Generated Visual Studio project files are local in this CMake-first project.
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# -------------------------
# CLion / JetBrains
# -------------------------
.idea/

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# vcpkg / dependency managers
# -------------------------
vcpkg_installed/
packages/
_deps/

# -------------------------
# Logs and temporary files
# -------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# -------------------------
# Local environment files
# -------------------------
.env
.env.*
!.env.example
